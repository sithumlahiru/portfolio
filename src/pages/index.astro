---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const work = (await getCollection("work", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base>
  <main class="mx-auto max-w-3xl px-6 py-24">
    <section id="top" class="border-b border-[var(--color-line)] pb-16">
      <p class="font-mono text-sm text-[var(--color-muted)]">Foundation running &#10003;</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight">Sithum Lahiru</h1>
      <p class="mt-3 max-w-prose text-lg text-[var(--color-muted)]">
        Product designer. This is the scaffold — real hero, type and palette come next.
      </p>
    </section>

    <section id="work" class="py-16">
      <h2 class="font-mono text-sm uppercase tracking-widest text-[var(--color-muted)]">Selected work</h2>
      <ul class="mt-6 space-y-4">
        {
          work.map((item) => (
            <li>
              <a href={`/work/${item.id}`} class="group flex items-baseline justify-between gap-4 border-b border-[var(--color-line)] py-4">
                <span class="text-lg group-hover:text-[var(--color-accent)]">{item.data.title}</span>
                <span class="shrink-0 font-mono text-sm text-[var(--color-muted)]">{item.data.domain} &#183; {item.data.year}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section id="about" class="border-t border-[var(--color-line)] py-16">
      <h2 class="font-mono text-sm uppercase tracking-widest text-[var(--color-muted)]">About</h2>
      <p class="mt-4 max-w-prose text-[var(--color-muted)]">Placeholder.</p>
    </section>

    <section id="contact" class="border-t border-[var(--color-line)] py-16">
      <h2 class="font-mono text-sm uppercase tracking-widest text-[var(--color-muted)]">Contact</h2>
      <p class="mt-4 max-w-prose text-[var(--color-muted)]">Placeholder.</p>
    </section>
  </main>
</Base>
