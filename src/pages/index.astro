---
import Base from "../layouts/Base.astro";

const experience = [
  { company: "Type B Digital", role: "Design Lead", location: "Canada · Remote", period: "2025 — Present" },
  { company: "Type B Digital", role: "Senior Product Designer", location: "Canada · Remote", period: "2024 — 2025" },
  { company: "InvoGuide", role: "Product Design Consultant", location: "New Zealand · Remote", period: "2024 — Present" },
  { company: "MacroActive", role: "Senior Product Designer", location: "New Zealand · Remote", period: "2021 — 2024" },
  { company: "Digital Yogin", role: "UI/UX Designer", location: "Italy · Remote", period: "2022 — 2023" },
  { company: "Data2Visual", role: "UI/UX Designer", location: "Germany · Remote", period: "2019 — 2021" },
  { company: "Ceyentra", role: "UI/UX Design Intern", location: "Sri Lanka · Remote", period: "2018 — 2019" },
];
---

<Base>
  <main class="mx-auto max-w-5xl px-6 py-16 md:px-10 md:py-20">
    <header id="top">
      <p class="font-mono text-xs uppercase leading-tight tracking-widest text-[var(--color-muted)]">
        Sithum<br />Lahiru
      </p>
    </header>

    <h1
      class="rise mt-14 max-w-[16ch] text-[clamp(2.5rem,7vw,5.5rem)] font-bold leading-[1.03] tracking-[-0.03em] md:mt-20"
    >
      Product designer &amp; design lead.
    </h1>

    {/* Case studies hidden for now — content still lives in src/content/work and the /work/[id] pages. */}

    <section
      id="experience"
      class="rise mt-28 border-t border-[var(--color-line)] pt-6"
      style="animation-delay:0.08s"
    >
      <h2 class="font-mono text-xs uppercase tracking-widest text-[var(--color-muted)]">
        Experience
      </h2>
      <ul class="mt-2">
        {
          experience.map((job) => (
            <li class="flex flex-col gap-1 border-b border-[var(--color-line)] py-6 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
              <div>
                <p class="text-xl font-medium tracking-tight md:text-2xl">{job.company}</p>
                <p class="mt-1 text-[var(--color-muted)]">{job.role}</p>
              </div>
              <p class="shrink-0 font-mono text-xs uppercase tracking-wider text-[var(--color-muted)]">
                {job.location} &#183; {job.period}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <section
      id="about"
      class="rise mt-28 border-t border-[var(--color-line)] pt-6"
      style="animation-delay:0.16s"
    >
      <h2 class="font-mono text-xs uppercase tracking-widest text-[var(--color-muted)]">
        About
      </h2>
      <p class="mt-6 max-w-2xl text-xl leading-relaxed text-[var(--color-ink)] md:text-2xl">
        I&rsquo;m a product designer and design lead based in Colombo, Sri Lanka,
        working remotely with teams across Canada, New Zealand, and Europe. Over
        the past eight years I&rsquo;ve designed SaaS, fintech, health, and AI
        products end-to-end &mdash; from 0&rarr;1 platforms and scalable design
        systems to leading and mentoring the teams that build them. I care about
        turning complex, high-stakes software into interfaces people trust.
      </p>
    </section>

    <section
      id="contact"
      class="rise mt-28 border-t border-[var(--color-line)] pb-24 pt-6"
      style="animation-delay:0.24s"
    >
      <h2 class="font-mono text-xs uppercase tracking-widest text-[var(--color-muted)]">
        Get in touch
      </h2>
      <ul class="mt-6 flex flex-wrap gap-x-10 gap-y-3 text-xl md:text-2xl">
        <li>
          <a
            class="underline decoration-[var(--color-line)] underline-offset-4 transition-colors hover:decoration-[var(--color-ink)]"
            href="mailto:sithumlahiru.ux@gmail.com"
          >
            Email
          </a>
        </li>
        <li>
          <a
            class="underline decoration-[var(--color-line)] underline-offset-4 transition-colors hover:decoration-[var(--color-ink)]"
            href="https://www.linkedin.com/in/sithumlahiru"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </li>
        <li>
          <a
            class="underline decoration-[var(--color-line)] underline-offset-4 transition-colors hover:decoration-[var(--color-ink)]"
            href="https://dribbble.com/sithumlahiru"
            target="_blank"
            rel="noopener noreferrer"
          >
            Dribbble
          </a>
        </li>
      </ul>
    </section>
  </main>
</Base>
