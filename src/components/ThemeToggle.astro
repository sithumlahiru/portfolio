---
// Floating theme picker. Swaps the [data-theme] attribute on <html>, which
// re-skins the whole site via CSS variables, and remembers the choice.
const themes = [
  { id: "paper", label: "Paper", swatch: "#e9e7df" },
  { id: "glass", label: "Glass", swatch: "linear-gradient(135deg, #2f9397, #0a3f48)" },
  {
    id: "pixel",
    label: "Pixel",
    swatch: "repeating-conic-gradient(#17170f 0% 25%, #efeee6 0% 50%) 0 0 / 6px 6px",
  },
  { id: "aurora", label: "Aurora", swatch: "linear-gradient(135deg, #7876f0, #f096aa 55%, #5aaaf0)" },
];
---

<div class="theme-toggle" role="group" aria-label="Colour theme">
  <span class="theme-toggle__label">Theme</span>
  {
    themes.map((t) => (
      <button
        type="button"
        data-theme-btn={t.id}
        class="theme-toggle__swatch"
        title={t.label}
        aria-label={t.label}
        style={`--sw:${t.swatch}`}
      />
    ))
  }
</div>

<style>
  .theme-toggle {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-paper) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 12px 34px -14px rgba(0, 0, 0, 0.4);
    transition: background 0.4s ease, border-color 0.4s ease;
  }

  .theme-toggle__label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-muted);
    padding-left: 0.15rem;
  }

  .theme-toggle__swatch {
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 999px;
    background: var(--sw);
    border: 1px solid rgba(0, 0, 0, 0.18);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.28);
    cursor: pointer;
    padding: 0;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .theme-toggle__swatch:hover {
    transform: scale(1.14);
  }

  .theme-toggle__swatch[aria-pressed="true"] {
    box-shadow: 0 0 0 2px var(--color-paper), 0 0 0 4px var(--color-ink);
  }

  @media (max-width: 480px) {
    .theme-toggle__label {
      display: none;
    }
  }

  /* Pixel theme: hard edges, no blur, chunky shadow */
  :global([data-theme="pixel"]) .theme-toggle {
    border-radius: 0;
    border-width: 2px;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    background: var(--color-paper);
    box-shadow: 4px 4px 0 var(--color-ink);
  }
  :global([data-theme="pixel"]) .theme-toggle__swatch {
    border-radius: 0;
  }
</style>

<script>
  const root = document.documentElement;
  const btns = Array.from(document.querySelectorAll("[data-theme-btn]"));

  function update() {
    const cur = root.getAttribute("data-theme") || "paper";
    btns.forEach((b) =>
      b.setAttribute(
        "aria-pressed",
        b.getAttribute("data-theme-btn") === cur ? "true" : "false",
      ),
    );
  }

  btns.forEach((b) =>
    b.addEventListener("click", () => {
      const t = b.getAttribute("data-theme-btn");
      if (!t) return;
      root.setAttribute("data-theme", t);
      try {
        localStorage.setItem("theme", t);
      } catch (e) {}
      update();
    }),
  );

  // Fall back to paper if the stored theme no longer exists (e.g. "editorial")
  const valid = btns.map((b) => b.getAttribute("data-theme-btn"));
  if (!valid.includes(root.getAttribute("data-theme") || "")) {
    root.setAttribute("data-theme", "paper");
    try {
      localStorage.setItem("theme", "paper");
    } catch (e) {}
  }
  update();
</script>
